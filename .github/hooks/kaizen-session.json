{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": "mkdir -p .kaizen && date -Iseconds > .kaizen/.pending-extract-copilot",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash .agents/skills/kaizen/scripts/kaizen-precommit-gate.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash .agents/skills/kaizen/scripts/kaizen-context-inject.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
