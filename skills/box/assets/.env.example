# Box スキルの環境変数テンプレート。`.env` に複製して値を設定する。
# 秘匿値（トークン・secret・refresh token）はコミットしない。

# --- 認証（どちらか一方）---
# 方式1: Dev Token（Box Developer Console 発行・60 分有効）。設定時はこちらを優先。
BOX_ACCESS_TOKEN=

# 方式2: OAuth refresh（持続的）。Client ID/Secret を設定し、初回だけ box-oauth-init.sh で
# refresh token を保存する（保存先は BOX_REFRESH_TOKEN_FILE、既定 ~/.config/box/refresh_token）。
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
# refresh token をファイルではなく環境変数で渡す場合のみ設定する（任意）。
# BOX_REFRESH_TOKEN=
# BOX_REFRESH_TOKEN_FILE=~/.config/box/refresh_token

# --- 操作対象 ---
# 既定の対象フォルダ ID（未設定時は Box ルート 0 にフォールバック）。
BOX_ROOT_FOLDER_ID=
