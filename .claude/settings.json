            "type": "command",
            "command": "bash .agents/skills/kaizen/scripts/kaizen-stop-mark.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agents/skills/kaizen/scripts/kaizen-precommit-gate.sh"
          }
        ]
      }
    ]
  }
