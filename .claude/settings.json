{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .kaizen && date -Iseconds > .kaizen/.pending-extract"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agents/skills/kaizen/scripts/kaizen-precommit-gate.sh"
          }
        ]
      }
    ]
  }
}
